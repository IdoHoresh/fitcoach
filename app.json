{
  "expo": {
    "name": "FitCoach",
    "slug": "fitcoach",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "fitcoach",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitcoach.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FitCoach uses the camera for progress photos",
        "NSPhotoLibraryUsageDescription": "FitCoach uses your photo library for progress photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.fitcoach.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-crypto"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
