{
  "expo": {
    "name": "Gibor",
    "slug": "gibor",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "gibor",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gibor.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Gibor uses the camera for progress photos",
        "NSPhotoLibraryUsageDescription": "Gibor uses your photo library for progress photos",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.gibor.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-sqlite", "expo-secure-store"],
    "extra": {
      "eas": {
        "projectId": "3457690d-f693-4be7-b686-546c24f4be38"
      },
      "router": {}
    }
  }
}
