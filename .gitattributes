# Normalize all text files to LF in the repo, regardless of OS.
# Prevents CRLF ghost diffs on Windows.
* text=auto eol=lf

# Ensure these are always treated as text
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
