        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qiE 'rm\\s+-rf\\s+(\\/|\\.|src|app|\\~)|--force\\s+push|drop\\s+table|truncate\\s+table' && echo 'BLOCKED: Dangerous command detected (rm -rf on protected paths, force push, DROP/TRUNCATE TABLE). rm -rf node_modules and rm -rf dist are allowed.' && exit 2 || exit 0"
