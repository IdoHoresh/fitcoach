{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Notion__notion-create-pages",
      "Bash(xargs wc:*)",
      "Bash(curl -s \"https://search.brave.com/api/suggest?q=carloss+app\")",
      "WebFetch(domain:carloss.com)",
      "WebFetch(domain:play.google.com)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://fitly.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://repp.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://coachly.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://movva.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://lifta.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://gympal.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://reppa.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://forma.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://pumpi.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://traini.com\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://hadar.app\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://nevo.app\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://kaddo.app\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://luko.app\")",
      "Bash(node -e ':*)",
      "Bash(git config:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -qiE '\\.(env|pem|key)$|credentials|secrets' && echo 'BLOCKED: Cannot write to sensitive files (.env, credentials, secrets, keys)' && exit 2 || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qiE 'rm\\s+-rf\\s+(\\/|\\.|src|app|\\~)|--force\\s+push|drop\\s+table|truncate\\s+table' && echo 'BLOCKED: Dangerous command detected (rm -rf on protected paths, force push, DROP/TRUNCATE TABLE). rm -rf node_modules and rm -rf dist are allowed.' && exit 2 || exit 0"
          }
        ]
      }
    ]
  }
}
